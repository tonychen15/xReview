#!/usr/bin/env bash
# xreview — xReview code review orchestrator
# Agents are responsible for logging and deciding next actions.
# This script is stateless tooling: write/read LOCK, trigger agents, exit.
set -euo pipefail

REVIEW_DIR=".review"
LOCK_FILE="$REVIEW_DIR/LOCK"
REVIEW_LOG="$REVIEW_DIR/REVIEW.md"
MAX_ITERATIONS=5

# Keep in sync with the VERSION file at the repo root.
XREVIEW_VERSION="0.2.0"

# These variables are set by read_lock() via eval of the LOCK file
AGENT="" STATE="" REVIEWER="" DEVELOPER="" ITERATION="" SESSION="" TYPE="" OBJECTIVE="" TIMESTAMP=""

# ── Agent Detection ───────────────────────────────────────────────────────────

KNOWN_AGENTS=(claude gemini codex)

# Reviewer preference when none is explicitly requested (highest priority first).
# Resolution falls through this list, then to any other installed peer, then to
# developer self-review as a last resort.
DEFAULT_REVIEWER_PRIORITY=(codex gemini)

detect_installed_agents() {
  local agents=()
  for a in "${KNOWN_AGENTS[@]}"; do
    command -v "$a" &>/dev/null && agents+=("$a")
  done
  echo "${agents[@]}"
}

is_known_agent() {
  local name="$1"
  for a in "${KNOWN_AGENTS[@]}"; do
    [[ "$a" == "$name" ]] && return 0
  done
  return 1
}

resolve_reviewer() {
  local developer="$1"
  local requested="${2:-}"
  local installed
  read -ra installed <<< "$(detect_installed_agents)"

  if [[ -n "$requested" ]]; then
    # Validate requested reviewer
    if ! is_known_agent "$requested"; then
      echo "ERROR: '$requested' is not a known agent (known: ${KNOWN_AGENTS[*]})" >&2
      exit 1
    fi
    if [[ "$requested" == "$developer" ]]; then
      echo "ERROR: reviewer cannot be the developer" >&2
      exit 1
    fi
    if ! command -v "$requested" &>/dev/null; then
      local peers=()
      for a in "${installed[@]}"; do
        [[ "$a" != "$developer" ]] && peers+=("$a")
      done
      if [[ ${#peers[@]} -gt 0 ]]; then
        echo "ERROR: $requested is not installed. Available reviewers: ${peers[*]}" >&2
      else
        echo "ERROR: $requested is not installed. No other agents available." >&2
      fi
      exit 1
    fi
    echo "$requested"
  else
    # No reviewer requested — pick by preference order: codex, then gemini, then
    # any other installed peer, then developer self-review as a last resort.
    local a
    for a in "${DEFAULT_REVIEWER_PRIORITY[@]}"; do
      if [[ "$a" != "$developer" ]] && command -v "$a" &>/dev/null; then
        echo "$a"
        return 0
      fi
    done
    # Fall back to any installed peer not covered by the priority list.
    for a in "${installed[@]}"; do
      if [[ "$a" != "$developer" ]]; then
        echo "$a"
        return 0
      fi
    done
    echo "WARNING: No other agents installed. $developer will self-review." >&2
    echo "$developer"
  fi
}

# ── Helpers ────────────────────────────────────────────────────────────────────

ts()    { date -u +"%Y-%m-%d %H:%M UTC"; }
epoch() { date +%s; }

read_lock() {
  [[ -f "$LOCK_FILE" ]] || return 1
  # Source the LOCK file — values with spaces are single-quoted
  eval "$(cat "$LOCK_FILE")"
}

write_lock() {
  # Single-quote OBJECTIVE to handle spaces
  cat > "$LOCK_FILE" <<EOF
AGENT=$1
STATE=$2
REVIEWER=$3
DEVELOPER=$4
ITERATION=$5
SESSION=$6
TYPE=$7
OBJECTIVE='$8'
TIMESTAMP=$(epoch)
EOF
}

next_session() {
  if [[ -f "$REVIEW_LOG" ]]; then
    local last
    last=$(grep -c "^## Session #" "$REVIEW_LOG" 2>/dev/null || true)
    [[ -z "$last" ]] && last=0
    echo $((last + 1))
  else
    echo 1
  fi
}

init_review_log() {
  mkdir -p "$REVIEW_DIR"
  if [[ ! -f "$REVIEW_LOG" ]]; then
    cat > "$REVIEW_LOG" <<'EOF'
# xReview Log

> Shared review channel between Claude Code and Gemini CLI.
> Sessions append below. Each agent logs its own state transitions.

---

EOF
  fi
}

trigger_agent() {
  local agent="$1"
  local prompt="$2"
  local mode="${3:-sync}"    # sync (default) or async

  local cmd
  case "$agent" in
    claude)
      if ! command -v claude &>/dev/null; then
        echo "ERROR: claude CLI not found in PATH" >&2
        exit 1
      fi
      cmd=(claude -p "$prompt" --allowedTools "Read,Write,Edit,Bash,Glob,Grep")
      ;;
    gemini)
      if ! command -v gemini &>/dev/null; then
        echo "ERROR: gemini CLI not found in PATH" >&2
        exit 1
      fi
      cmd=(gemini -p "$prompt")
      ;;
    codex)
      if ! command -v codex &>/dev/null; then
        echo "ERROR: codex CLI not found in PATH" >&2
        exit 1
      fi
      # Both roles must write under .review/ (the reviewer records its verdict and
      # clears LOCK), so workspace-write is required — read-only would block those
      # writes. The review-only constraint is enforced by the prompt, exactly as it
      # is for claude/gemini. ("suggest" is not a valid codex sandbox mode.)
      cmd=(codex exec "$prompt" -C "$(pwd)" -s workspace-write)
      ;;
    *)
      echo "ERROR: unknown agent '$agent'" >&2
      exit 1
      ;;
  esac

  local logfile
  logfile="$REVIEW_DIR/${agent}-$(date +%s).log"

  if [[ "$mode" == "async" ]]; then
    echo "Launching $agent (log: $logfile)"
    "${cmd[@]}" > "$logfile" 2>&1 &
    wait $! 2>/dev/null || true
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  Reviewer output ($agent):"
    echo "═══════════════════════════════════════════════════════════════"
    cat "$logfile"
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  Full log: $logfile"
    echo "═══════════════════════════════════════════════════════════════"
  else
    "${cmd[@]}" 2>&1 | tee "$logfile" || true
    echo ""
    echo "(Full log: $logfile)"
  fi
}

# ── Subcommands ────────────────────────────────────────────────────────────────

cmd_task() {
  local type="$1"       # bugfix, feature, refactor
  local agent="$2"      # developer agent
  local reviewer="$3"   # reviewer agent (resolved)
  local desc="$4"       # objective description

  local session
  session=$(next_session)

  init_review_log

  write_lock "$agent" "implementing" "$reviewer" "$agent" "1" "$session" "$type" "$desc"

  # Print instructions for the calling agent (it's already running)
  cat <<EOF
═══════════════════════════════════════════════════════════════
  xReview — Session #${session}
  Type: ${type} | Developer: ${agent} | Reviewer: ${reviewer}
  Objective: ${desc}
═══════════════════════════════════════════════════════════════

You are the DEVELOPER for this session.

1. Append the session header and "Implementing" line to ${REVIEW_LOG}
2. Implement the changes: ${desc}
3. When done, run:  xreview review

Session format to append to ${REVIEW_LOG}:

## Session #${session} — $(ts)
**Type:** ${type} | **Developer:** ${agent} | **Reviewer:** ${reviewer}
**Objective:** ${desc}

### Iteration 1
- **Implementing** — ${agent} — $(ts)
EOF
}

cmd_review() {
  if ! read_lock; then
    echo "ERROR: no active session (LOCK file missing)" >&2
    exit 1
  fi

  if [[ "$ITERATION" -gt "$MAX_ITERATIONS" ]]; then
    echo "ERROR: max iterations ($MAX_ITERATIONS) reached for session #$SESSION." >&2
    echo "Run 'xreview unlock' and intervene manually." >&2
    exit 1
  fi

  local reviewer="$REVIEWER"
  local developer="$DEVELOPER"
  write_lock "$reviewer" "reviewing" "$REVIEWER" "$DEVELOPER" "$ITERATION" "$SESSION" "$TYPE" "$OBJECTIVE"

  echo "Triggering reviewer: $reviewer (async)"
  trigger_agent "$reviewer" "You are the REVIEWER for xreview session #${SESSION} (iteration ${ITERATION}).

Your task:
1. Read .review/REVIEW.md to understand the objective
2. Run 'git diff' to see the changes
3. Append a reviewing line to .review/REVIEW.md:
   - **Reviewing** — ${reviewer} — $(date -u +'%Y-%m-%d %H:%M UTC')
4. Evaluate the changes against the stated objective
5. Write your verdict in .review/REVIEW.md under the current iteration, using '- ' bullet prefix to keep it grouped with the Implementing/Reviewing lines:

   - **Verdict:** APPROVED or NEEDS_CHANGES
   - **Findings:** your analysis
   - **Action Items:** numbered list (if any)

6. Finalize the session directly (do NOT call xreview commit or rework):

   If APPROVED:
   - Append to .review/REVIEW.md WITHOUT '- ' prefix (top-level, not indented under the iteration):
     **Session #${SESSION} complete — <current UTC timestamp>**
   - Remove .review/LOCK (run: rm -f .review/LOCK)
   - The developer (${developer}) will handle committing separately.

   If NEEDS_CHANGES:
   - Leave .review/LOCK in place (the developer will read your Action Items and rework)

IMPORTANT: You are in REVIEW-ONLY mode. Do NOT edit any source files. Only edit .review/REVIEW.md.
IMPORTANT: Do NOT call xreview commit or xreview rework. Handle finalization inline as described above." "async"
}

cmd_commit() {
  if ! read_lock; then
    echo "ERROR: no active session" >&2
    exit 1
  fi

  local developer="$DEVELOPER"
  write_lock "$developer" "committing" "$REVIEWER" "$DEVELOPER" "$ITERATION" "$SESSION" "$TYPE" "$OBJECTIVE"

  echo "Triggering developer: $developer (commit)"
  trigger_agent "$developer" "xReview session #${SESSION} has been APPROVED by the reviewer.

Your task:
1. Commit the changes with a descriptive commit message
2. Append the session-complete line to .review/REVIEW.md:
   **Session #${SESSION} complete — $(date -u +'%Y-%m-%d %H:%M UTC') (Duration: calculate from session start)**
3. The session is done.

After committing, remove .review/LOCK to release the session."
}

cmd_rework() {
  if ! read_lock; then
    echo "ERROR: no active session" >&2
    exit 1
  fi

  local new_iter=$((ITERATION + 1))
  if [[ "$new_iter" -gt "$MAX_ITERATIONS" ]]; then
    echo "ERROR: max iterations ($MAX_ITERATIONS) reached for session #$SESSION." >&2
    echo "Run 'xreview unlock' and intervene manually." >&2
    exit 1
  fi

  local developer="$DEVELOPER"
  write_lock "$developer" "reworking" "$REVIEWER" "$DEVELOPER" "$new_iter" "$SESSION" "$TYPE" "$OBJECTIVE"

  echo "Triggering developer: $developer (rework, iteration $new_iter)"
  trigger_agent "$developer" "xReview session #${SESSION} needs changes (iteration ${new_iter}/${MAX_ITERATIONS}).

Your task:
1. Read .review/REVIEW.md — find the reviewer's Action Items
2. Append a new iteration header and reworking line to .review/REVIEW.md:
   ### Iteration ${new_iter}
   - **Reworking** — ${developer} — $(date -u +'%Y-%m-%d %H:%M UTC')
3. Address all the Action Items
4. When done, run:  xreview review"
}

cmd_nobug() {
  if ! read_lock; then
    echo "ERROR: no active session" >&2
    exit 1
  fi

  echo "Session #${SESSION}: no bug found. Closing session."
  echo ""
  echo "Append this to .review/REVIEW.md to close the session:"
  echo ""
  echo "- **No bug found** — $(date -u +'%Y-%m-%d %H:%M UTC')"
  echo ""
  echo "**Session #${SESSION} complete — $(date -u +'%Y-%m-%d %H:%M UTC') (No changes needed)**"

  rm -f "$LOCK_FILE"
  echo ""
  echo "Lock released. Session closed."
}

cmd_status() {
  if [[ ! -f "$LOCK_FILE" ]]; then
    echo "No active session."
    return
  fi
  echo "=== xReview Status ==="
  cat "$LOCK_FILE"
  echo ""
  echo "Installed agents: $(detect_installed_agents)"
  echo "================================"
}

cmd_unlock() {
  if [[ -f "$LOCK_FILE" ]]; then
    rm -f "$LOCK_FILE"
    echo "Lock released. Session can be restarted."
  else
    echo "No lock to release."
  fi
}

# ── Main ───────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: xreview <dev-agent> <task> [rev-agent] "<description>"

  <dev-agent>   Developer agent: claude, gemini, or codex
  <task>        Task type: bugfix, feature, or refactor
  [rev-agent]   Reviewer agent (optional — random if omitted)
  "<description>" What to do

Examples:
  xreview claude bugfix gemini "fix the phone extension bug"
  xreview gemini feature "add dark mode"
  xreview codex refactor claude "extract shared package"

Other commands:
  xreview review                    Trigger reviewer (called by developer)
  xreview commit                    Trigger commit (called by reviewer, APPROVED)
  xreview rework                    Trigger rework (called by reviewer, NEEDS_CHANGES)
  xreview nobug                     Close session — no bug found (called by developer)
  xreview status                    Show current session state
  xreview unlock                    Emergency: clear lock file
  xreview version                   Print the installed xreview version

Agents: ${KNOWN_AGENTS[*]}
Installed: $(detect_installed_agents)
EOF
}

case "${1:-}" in
  review)   cmd_review ;;
  commit)   cmd_commit ;;
  rework)   cmd_rework ;;
  nobug)    cmd_nobug ;;
  status)   cmd_status ;;
  unlock)   cmd_unlock ;;
  version|--version|-v) echo "xreview ${XREVIEW_VERSION}" ;;
  -h|--help|help) usage ;;
  *)
    # New format: xreview <dev-agent> <task> [rev-agent] "<description>"
    developer="${1:-}"
    task_type="${2:-}"
    shift 2 2>/dev/null || true

    # Validate developer
    if ! is_known_agent "$developer"; then
      echo "ERROR: '$developer' is not a known agent (known: ${KNOWN_AGENTS[*]})" >&2
      echo ""
      usage
      exit 1
    fi

    # Validate task type
    case "$task_type" in
      bugfix|feature|refactor) ;;
      *)
        echo "ERROR: '$task_type' is not a valid task (must be: bugfix, feature, refactor)" >&2
        echo ""
        usage
        exit 1
        ;;
    esac

    # Next arg: if it's a known agent, it's the reviewer. Otherwise it's description.
    requested_reviewer=""
    if is_known_agent "${1:-}"; then
      requested_reviewer="$1"
      shift
    fi

    # Remaining args are the description
    desc="${*:-}"
    [[ -n "$desc" ]] || { echo "ERROR: description is required"; exit 1; }

    reviewer=$(resolve_reviewer "$developer" "$requested_reviewer")
    cmd_task "$task_type" "$developer" "$reviewer" "$desc"
    ;;
esac
